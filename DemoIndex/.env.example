# DemoIndex shared configuration
# Main precedence: explicit Python / CLI args > DemoIndex/.env > code defaults

########################################
# 1. Shared base configuration
########################################

# PostgreSQL connection string for tree/global-index persistence and retrieval.
# No code default. Required when PostgreSQL-backed flows are enabled.
DEMOINDEX_DATABASE_URL=postgresql://demoindex:demoindex@127.0.0.1:5432/demoindex

# Enable structured debug logs by default.
# Default: false
DEMOINDEX_DEBUG_LOG=false

# Optional directory for structured debug logs.
# Default: unset -> build uses <artifacts-dir>/debug, retrieval uses DemoIndex/artifacts/retrieval/<timestamp>/debug
DEMOINDEX_DEBUG_LOG_DIR=

# Optional retrieval profile JSON for metric/region/platform/genre aliases.
# Default: unset
DEMOINDEX_RETRIEVAL_PROFILE_PATH=

########################################
# 2. Chat LLM API configuration
########################################

# Supported values: dashscope / openai
# Default: dashscope
DEMOINDEX_LLM_API_PROVIDER=dashscope

# Required for chat paths when the selected provider is used.
DEMOINDEX_LLM_API_KEY=

# Default:
#   dashscope -> https://dashscope.aliyuncs.com/compatible-mode/v1
#   openai    -> https://api.openai.com/v1
DEMOINDEX_LLM_BASE_URL=

# Default: 180
DEMOINDEX_LLM_TIMEOUT_SECONDS=180

# Default: 4
DEMOINDEX_LLM_MAX_RETRIES=4

# Default: 1.5
DEMOINDEX_LLM_RETRY_BASE_SECONDS=1.5

# Default: 4
DEMOINDEX_LLM_MAX_CONCURRENCY=4

########################################
# 3. Embedding API configuration
########################################

# Supported values: dashscope / openai
# Default: dashscope
DEMOINDEX_EMBEDDING_API_PROVIDER=dashscope

# Required for embedding paths when the selected provider is used.
DEMOINDEX_EMBEDDING_API_KEY=

# Default:
#   dashscope -> https://dashscope.aliyuncs.com/compatible-mode/v1
#   openai    -> https://api.openai.com/v1
DEMOINDEX_EMBEDDING_BASE_URL=

# Default: 180
DEMOINDEX_EMBEDDING_TIMEOUT_SECONDS=180

# Default: 4
DEMOINDEX_EMBEDDING_MAX_RETRIES=4

# Default: 10
DEMOINDEX_EMBEDDING_MAX_BATCH_SIZE=10

# Default:
#   dashscope -> 1024
#   openai    -> unset (request omits dimensions and lets provider/model decide)
DEMOINDEX_EMBEDDING_DIMENSIONS=

########################################
# 4. Build pipeline defaults
########################################

# Default: dashscope/qwen3.6-plus
DEMOINDEX_BUILD_MODEL=dashscope/qwen3.6-plus

# Default: dashscope/qwen3.5-plus
DEMOINDEX_BUILD_FALLBACK_MODEL=dashscope/qwen3.5-plus

# Default: false
DEMOINDEX_BUILD_INCLUDE_SUMMARY=false

# Default: false
DEMOINDEX_BUILD_WRITE_POSTGRES=false

# Default: false
DEMOINDEX_BUILD_WRITE_GLOBAL_INDEX=false

# Default: text-embedding-v4
DEMOINDEX_BUILD_GLOBAL_INDEX_MODEL=text-embedding-v4

# Supported values: auto / h1_forest / page_per_page
# Default: auto
DEMOINDEX_BUILD_MARKDOWN_LAYOUT=auto

# Optional build artifacts directory.
# Default: unset -> DemoIndex/artifacts/<input_stem>
DEMOINDEX_BUILD_ARTIFACTS_DIR=

########################################
# 5. Retrieval Stage 1-2 defaults
########################################

# Default: true
DEMOINDEX_RETRIEVAL_USE_LLM_PARSE=true

# Default: dashscope/qwen3.6-plus
DEMOINDEX_RETRIEVAL_PARSE_MODEL=dashscope/qwen3.6-plus

# Default: dashscope/qwen3.5-plus
DEMOINDEX_RETRIEVAL_PARSE_FALLBACK_MODEL=dashscope/qwen3.5-plus

# Default: text-embedding-v4
DEMOINDEX_RETRIEVAL_EMBEDDING_MODEL=text-embedding-v4

# Default: 60
DEMOINDEX_RETRIEVAL_TOP_K_DENSE=60

# Default: 60
DEMOINDEX_RETRIEVAL_TOP_K_LEXICAL=60

# Default: 80
DEMOINDEX_RETRIEVAL_TOP_K_FUSED_CHUNKS=80

# Default: 10
DEMOINDEX_RETRIEVAL_TOP_K_DOCS=10

# Default: 3
DEMOINDEX_RETRIEVAL_TOP_K_SECTIONS_PER_DOC=3

# Default: 2
DEMOINDEX_RETRIEVAL_TOP_K_CHUNKS_PER_SECTION=2

# Default: 60
DEMOINDEX_RETRIEVAL_RRF_K=60

# Default: 0.18
DEMOINDEX_RETRIEVAL_LEXICAL_SCORE_THRESHOLD=0.18

# Default: 5
DEMOINDEX_RETRIEVAL_DOC_SCORE_CHUNK_LIMIT=5

# Default: 3
DEMOINDEX_RETRIEVAL_SECTION_SCORE_CHUNK_LIMIT=3

########################################
# 6. Stage 3 defaults
########################################

# Supported values: heuristic / hybrid
# Default: hybrid
DEMOINDEX_STAGE3_MODE=hybrid

# Default: 5
DEMOINDEX_STAGE3_TOP_K_TREE_SECTIONS_PER_DOC=5

# Default: 3
DEMOINDEX_STAGE3_TOP_K_ANCHOR_SECTIONS_PER_DOC=3

# Default: true
DEMOINDEX_STAGE3_WHOLE_DOC_FALLBACK=true

# Default: dashscope/qwen3.6-plus
DEMOINDEX_STAGE3_RERANK_MODEL=dashscope/qwen3.6-plus

# Default: dashscope/qwen3.5-plus
DEMOINDEX_STAGE3_RERANK_FALLBACK_MODEL=dashscope/qwen3.5-plus

# Default: 8
DEMOINDEX_STAGE3_SHORTLIST_SIZE=8

# Default:
# {"anchor":4.0,"descendant":2.75,"ancestor":2.1,"sibling":1.45,"doc_fallback":0.55}
DEMOINDEX_STAGE3_RELATION_PRIORS_JSON=

########################################
# 7. Stage 4 defaults
########################################

# Default: 3
DEMOINDEX_STAGE4_TOP_K_FOCUS_SECTIONS_PER_DOC=3

# Default: 2
DEMOINDEX_STAGE4_MAX_ANCESTOR_HOPS=2

# Default: 1
DEMOINDEX_STAGE4_MAX_DESCENDANT_DEPTH=1

# Default: 2
DEMOINDEX_STAGE4_MAX_SIBLINGS_PER_FOCUS=2

# Default: 1
DEMOINDEX_STAGE4_CHUNK_NEIGHBOR_WINDOW=1

# Default: 6
DEMOINDEX_STAGE4_MAX_EVIDENCE_CHUNKS_PER_FOCUS=6

# Default: 6000
DEMOINDEX_STAGE4_CONTEXT_CHAR_BUDGET=6000

########################################
# 8. Stage 5 defaults
########################################

# Supported values: heuristic / hybrid
# Default: heuristic
DEMOINDEX_STAGE5_RELATION_MODE=heuristic

# Default: 3
DEMOINDEX_STAGE5_TOP_K_EVIDENCE_PER_DOC=3

# Default: 8
DEMOINDEX_STAGE5_TOP_K_TOTAL_EVIDENCE=8

# Default: dashscope/qwen3.6-plus
DEMOINDEX_STAGE5_RELATION_MODEL=dashscope/qwen3.6-plus

# Default: dashscope/qwen3.5-plus
DEMOINDEX_STAGE5_RELATION_FALLBACK_MODEL=dashscope/qwen3.5-plus

# Default: 8
DEMOINDEX_STAGE5_RELATION_SHORTLIST_SIZE=8
